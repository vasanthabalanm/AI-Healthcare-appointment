# ── Database ───────────────────────────────────────────────────────────────
# Single PostgreSQL database (consolidated from SQL Server + PostgreSQL)
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=clinical_dev;Username=postgres;Password=admin;

# Redis — leave blank to use in-memory no-op fallback (Redis not required)
REDIS_CONNECTION_STRING=

# ── JWT / Session ───────────────────────────────────────────────────────────
# 32+ char secret — change before production deployment
JWT_SECRET=ClinicalHub_Dev_Secret_2026_ChangeMeInProd!
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=86400

# ── Email (SMTP — set to a real host for delivery; leave blank to silently drop emails) ──
# To enable real email, set SMTP_HOST to your SMTP server and configure other vars.
# For local dev with Mailpit: SMTP_HOST=localhost SMTP_PORT=1025 (start with: mailpit or docker run axllent/mailpit)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=ClinicalHub

# ── AI / Ollama (local) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── AI Chat Provider (Groq — OpenAI-compatible) ─────────────────────────────
OPENAI_BASE_URL=https://api.groq.com/openai
OPENAI_API_KEY=your_groq_api_key_here
OPENAI_CHAT_MODEL=llama-3.3-70b-versatile

# ── Embedding Provider (Jina AI) ────────────────────────────────────────────
EMBEDDING_BASE_URL=https://api.jina.ai
EMBEDDING_API_KEY=your_jina_api_key_here
EMBEDDING_MODEL=jina-embeddings-v3

# ── Calendar Sync ────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=replace_with_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=replace_with_google_client_secret
OUTLOOK_CLIENT_ID=replace_with_outlook_client_id
OUTLOOK_CLIENT_SECRET=replace_with_outlook_client_secret

# ── Serilog / Observability ──────────────────────────────────────────────────
SEQ_SERVER_URL=http://localhost:5341
SEQ_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200
