WHERE a."Status" <> 3 AND CAST(s."SlotTime" AT TIME ZONE 'UTC' AS date) = @__targetDate_0
2026-05-28 21:42:05.773 +05:30 [INF] ea29a3a2-c112-4b89-b44b-f46c924f761a Executed DbCommand (4ms) [Parameters=[@__targetDate_0='?' (DbType = Date), @__p_2='?' (DbType = Int32), @__p_1='?' (DbType = Int32)], CommandType='"Text"', CommandTimeout='30']
SELECT t."Id", t."PatientId", t1."FirstName" || ' ' || t1."LastName", t."SlotTime", t."Status", CASE
    WHEN t0."Id" IS NOT NULL THEN 'Submitted'
    WHEN t1."WalkIn" THEN 'NA'
    ELSE 'Pending'
END, t."IsHighRisk"
FROM (
    SELECT a."Id", a."IsHighRisk", a."PatientId", a."Status", s."SlotTime"
    FROM "Appointments" AS a
    INNER JOIN "Slots" AS s ON a."SlotId" = s."Id"
    WHERE a."Status" <> 3 AND CAST(s."SlotTime" AT TIME ZONE 'UTC' AS date) = @__targetDate_0
    ORDER BY s."SlotTime"
    LIMIT @__p_2 OFFSET @__p_1
) AS t
LEFT JOIN (
    SELECT i."Id", i."PatientId"
    FROM "IntakeRecords" AS i
    WHERE i."IsLatest" AND NOT (i."IsDeleted")
) AS t0 ON t."PatientId" = t0."PatientId"
INNER JOIN (
    SELECT u."Id", u."FirstName", u."LastName", u."WalkIn"
    FROM "UserAccounts" AS u
    WHERE NOT (u."IsDeleted")
) AS t1 ON t."PatientId" = t1."Id"
ORDER BY t."SlotTime"
