<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>
      <!--
        processPath="dotnet"  — use the installed .NET runtime on the server
        arguments             — entry-point DLL name matches the project output
        hostingModel          — "inprocess" runs inside the IIS worker process (w3wp.exe)
                                for lower latency and shared process lifecycle
        stdoutLogEnabled      — set to true temporarily when diagnosing startup failures;
                                always false in production to avoid disk growth
        ASPNETCORE_ENVIRONMENT is NOT set here (AC-005). Set it via:
          IIS Manager → Application Pools → [pool] → Advanced Settings →
          Environment Variables  (or via Azure App Service app settings)
      -->
      <aspNetCore processPath="dotnet"
                  arguments=".\ClinicalHealthcare.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
